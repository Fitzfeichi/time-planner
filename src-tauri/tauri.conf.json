{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "半小时日计划",
  "version": "0.1.0",
  "identifier": "local.time-block-planner",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "半小时日计划",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 620,
        "backgroundColor": "#eef2f6"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
